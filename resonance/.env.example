# Resonance — standalone, embeddable hangout world.
#
# Today these CAN point at the shared Frequency Supabase project (schema
# `resonance`). To break the app out into its own database later, create a fresh
# Supabase project, run resonance/supabase/migrations there, and swap ONLY the
# values below. No application code changes. See docs/ISOLATION.md.

# --- Data (server-side, service role). NEVER expose to the browser. ---
RESONANCE_SUPABASE_URL=https://your-project.supabase.co
RESONANCE_SUPABASE_SERVICE_ROLE_KEY=

# --- Realtime (browser): Broadcast + Presence channels only, never table reads. ---
NEXT_PUBLIC_RESONANCE_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_RESONANCE_SUPABASE_ANON_KEY=

# --- Federated identity (embedded mode) ---
# Public key used to verify host-issued JWTs (Frequency signs, we verify).
RESONANCE_HOST_JWT_PUBLIC_KEY=
# Secret we use to sign server-to-server webhooks back to the host economy.
RESONANCE_WEBHOOK_SIGNING_SECRET=

# --- Media ---
NEXT_PUBLIC_YOUTUBE_API_KEY=

# --- Payments (Phase 2+) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
