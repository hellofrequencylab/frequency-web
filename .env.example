# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Canonical public site URL used for SEO metadata, sitemap, and JSON-LD.
# Falls back to NEXT_PUBLIC_APP_URL (then the Vercel domain) if unset, but
# should be set explicitly in production to the apex domain.
NEXT_PUBLIC_SITE_URL=https://findafreq.com

# MapLibre style URL for circle maps — optional, defaults to OpenFreeMap.
NEXT_PUBLIC_MAP_STYLE=https://tiles.openfreemap.org/styles/positron

# Email (Resend) — optional, app works without these
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Frequency <noreply@yourdomain.com>
# Verifies inbound Resend webhook signatures (bounce/complaint handling).
# Required if you configure a Resend webhook; otherwise events are rejected.
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel Cron — required for scheduled dispatches and lifecycle triggers
CRON_SECRET=your-cron-secret

# Unsubscribe link HMAC signing — required for legitimate bulk email
# deliverability (Gmail/Yahoo require RFC 8058 one-click unsubscribe).
# Use a 32+ byte random string. Falls back to SUPABASE_SERVICE_ROLE_KEY
# in dev, but an explicit secret means tokens survive key rotation.
UNSUBSCRIBE_SECRET=your-unsubscribe-secret

# Beta confirmation link HMAC signing. Falls back to UNSUBSCRIBE_SECRET if
# unset; set explicitly so beta-confirm tokens survive key rotation.
BETA_CONFIRM_SECRET=your-beta-confirm-secret

# Web Push (VAPID) — required for browser push notifications.
# Generate with: node -e "console.log(require('web-push').generateVAPIDKeys())"
# Public key is also exposed to the browser. VAPID_SUBJECT is a contact URL
# (usually mailto:) push services use if they need to reach you.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:hello@hellofrequency.com
