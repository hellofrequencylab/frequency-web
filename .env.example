# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Canonical public URL used for SEO/sitemap/JSON-LD (lib/site.ts). Falls back to
# a sensible default if unset; set explicitly in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# App version surfaced in support context (lib/support/context.ts) so a ticket
# records which build the member was on. Optional — usually wired to the deploy SHA.
NEXT_PUBLIC_APP_VERSION=
# Google Analytics 4 measurement ID ("G-XXXXXXXXXX"). Optional — the GA tag
# (components/analytics/google-analytics.tsx) only loads when this is set AND
# NODE_ENV is production, so dev/preview traffic never hits your reports.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# GA4 Measurement Protocol API secret (GA4 → Admin → Data Streams → Measurement
# Protocol API secrets). Enables SERVER-SIDE event mirroring (lib/analytics/ga-server.ts)
# so QR scans / referral signups / gift-zaps reach GA4 even when the redirect leaves the
# site. Optional — server mirroring stays inert until BOTH this and the ID are set.
GA_API_SECRET=

# Email (Resend) — optional, app works without these.
# EMAIL_FROM must be on a domain verified in Resend. We use the `send.` subdomain
# so bulk reputation is isolated from the human-mail apex (see docs/LAUNCH.md §4).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Frequency <noreply@send.frequencylocal.com>
# Resend webhook signing secret ("whsec_...") — verifies inbound
# bounce/complaint/delivery webhooks at /api/webhooks/resend.
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
# Physical mailing address for the CAN-SPAM footer on bulk email (lib/email.ts).
# Optional — falls back to the org identity, but a real postal address is required
# for compliant bulk sending.
COMPANY_POSTAL_ADDRESS=

# Vercel Cron — required for scheduled dispatches and lifecycle triggers
CRON_SECRET=your-cron-secret

# Cron heartbeats / dead-man's-switch (H0-5) — OPTIONAL. When unset, the cron
# wrapper (lib/observability/cron-heartbeat.ts) is a safe no-op: jobs run exactly as
# before, just with no external "still alive" ping. Configure EITHER a single base
# URL (the job name is appended as the final path segment, e.g. Healthchecks.io /
# Better Stack) OR a per-job override. On success the wrapper POSTs the monitor URL;
# on failure it POSTs `${url}/fail`. Set up one monitor per job in your provider.
#   Base form:    CRON_HEARTBEAT_BASE_URL=https://hc-ping.com/<uuid-prefix>
#   Per-job form: CRON_HEARTBEAT_URL_<JOB> where <JOB> is the job name upper-snaked
#                 (e.g. CRON_HEARTBEAT_URL_PROCESS_QUEUE, CRON_HEARTBEAT_URL_WEEKLY_DIGEST)
CRON_HEARTBEAT_BASE_URL=

# Error monitoring — Sentry (H0-4) — OPTIONAL. The whole integration is a safe no-op
# until a DSN is set: with no DSN, Sentry never initialises (lib/observability/sentry.ts),
# every capture call is inert, and the build still succeeds. NEXT_PUBLIC_SENTRY_DSN is
# read on BOTH server and client (the public prefix lets the browser bundle see it);
# SENTRY_DSN is a server-only fallback. Get the DSN from the Sentry project settings.
NEXT_PUBLIC_SENTRY_DSN=
# Build-time source-map upload (optional, for readable client stack traces). Only used
# by withSentryConfig at build; unset → upload is skipped, build is unaffected. Keep
# SENTRY_AUTH_TOKEN secret (CI env var, never committed).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Optional tuning. Trace sample rate 0–1 (default 1.0 dev / 0.1 prod); environment +
# release default from Vercel's VERCEL_ENV / VERCEL_GIT_COMMIT_SHA when present.
SENTRY_TRACES_SAMPLE_RATE=

# Unsubscribe link HMAC signing — required for legitimate bulk email
# deliverability (Gmail/Yahoo require RFC 8058 one-click unsubscribe).
# Use a 32+ byte random string. Falls back to SUPABASE_SERVICE_ROLE_KEY
# in dev, but an explicit secret means tokens survive key rotation.
UNSUBSCRIBE_SECRET=your-unsubscribe-secret

# Signs Beta confirm/invite tokens (lib/beta-tokens.ts). Falls back to
# UNSUBSCRIBE_SECRET, then the service-role key, but set it explicitly so
# Beta tokens survive key rotation.
BETA_CONFIRM_SECRET=your-beta-confirm-secret

# Web Push (VAPID) — required for browser push notifications.
# Generate with: node -e "console.log(require('web-push').generateVAPIDKeys())"
# Public key is also exposed to the browser. VAPID_SUBJECT is a contact URL
# (usually mailto:) push services use if they need to reach you.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:hello@frequencylocal.com

# Maps — optional. Override the default OpenFreeMap style with a
# Mapbox/MapTiler style URL (components/circles/circle-map.tsx).
NEXT_PUBLIC_MAP_STYLE=https://tiles.openfreemap.org/styles/positron

# AI operator (Studio agent) — optional. When set, the lapsed-member win-back
# proposer drafts email copy with Claude (lib/studio/winback.ts); without it the
# proposer falls back to a deterministic template, so nothing breaks. The agent
# only ever PROPOSES — a human approves before anything sends.
ANTHROPIC_API_KEY=your-anthropic-api-key

# Stripe membership billing (P2.2) — optional, ENV-GATED. The whole billing layer
# stays dormant until STRIPE_SECRET_KEY is set (billingEnabled() is false, beta stays
# free); the moment it's set, checkout + the webhook go live with no code change
# (lib/billing/stripe.ts). sk_test_… in sandbox, sk_live_… in production.
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# Webhook signing secret (whsec_…) from the Stripe webhook endpoint. Without it the
# webhook route returns 503, so subscriptions never confirm — required to go live.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
# Price IDs (price_…) for the paid tiers. Optional — when unset, checkout builds an
# inline price from the *_AMOUNT values below.
STRIPE_PRICE_CREW=
STRIPE_PRICE_SUPPORTER=
# Inline-price fallback amounts in CENTS, used only when the matching price id above
# is unset. Defaults: Crew 1000 ($10), Supporter 2500 ($25). Set these (or the price
# ids) in production so the charged price is intentional, not the silent default.
STRIPE_MEMBERSHIP_AMOUNT=1000
STRIPE_SUPPORTER_AMOUNT=2500
# Platform fee percent (0–100) taken on creator tips/tickets (lib/billing/fees.ts).
# Defaults to 10 when unset.
STRIPE_PLATFORM_FEE_PCT=10

# Google Wallet passes — optional (ADR-108). When ALL three are set, members get an
# "Add to Google Wallet" button for their profile code (lib/wallet/google.ts signs
# the Save-to-Wallet JWT with node:crypto — no extra dependency). When any is unset,
# the feature stays dark (button hidden, /api/wallet/google 404s). Get these from the
# Google Wallet console: a numeric issuer id + a service-account key.
GOOGLE_WALLET_ISSUER_ID=your-google-wallet-issuer-id
GOOGLE_WALLET_SA_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_WALLET_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Rate limiting (Upstash Redis via the Vercel integration — KV_* naming).
KV_REST_API_URL=
KV_REST_API_TOKEN=
