import { describe, it, expect, beforeEach, vi } from 'vitest'

// FOUNDERS ROUND ONE-TIME CHECKOUT (createFounderCheckout). MONEY CODE — the test that
// matters most is the NO-CHARGE-WHEN-OFF invariant: while billingLive() is false, the
// action returns { ok:false, notOpen:true } and the Stripe client is NEVER touched (no
// session, no charge, no card). When billingLive() is true (mocked), it creates a
// mode:'payment' session carrying the right founder_tier metadata and returns the URL.
//
// Everything network-touching is mocked (Stripe, the gate, the price-map, the session
// profile), mirroring the repo's server-action test conventions (founders/actions.test.ts).

// ── Spies via vi.hoisted so they exist when the hoisted vi.mock factories run. ──
const {
  // The Stripe session-create spy, asserted NEVER called while billing is OFF.
  sessionsCreate,
  sessionsRetrieve,
  billingLiveMock,
  resolveStripePriceId,
  getUser,
  profilesMaybeSingle,
  grantFounderFromSession,
} = vi.hoisted(() => ({
  sessionsCreate: vi.fn(),
  sessionsRetrieve: vi.fn(),
  billingLiveMock: vi.fn(),
  resolveStripePriceId: vi.fn(),
  getUser: vi.fn(),
  profilesMaybeSingle: vi.fn(),
  grantFounderFromSession: vi.fn(),
}))

// The whole Stripe module mocked with a spied client, so we can prove it is untouched
// while billing is OFF, and inspect the session params when it is ON.
vi.mock('@/lib/billing/stripe', () => ({
  stripe: { checkout: { sessions: { create: sessionsCreate, retrieve: sessionsRetrieve } } },
  appUrl: () => 'https://frequencylocal.com',
}))
vi.mock('@/lib/pricing/settings', () => ({ billingLive: billingLiveMock }))
vi.mock('@/lib/billing/pricing-prices', () => ({ resolveStripePriceId }))
vi.mock('@/lib/billing/founders', async (importOriginal) => {
  // Keep the real PURE helpers (tier catalog, amounts, key) but mock the grant (DB write).
  const actual = await importOriginal<typeof import('@/lib/billing/founders')>()
  return { ...actual, grantFounderFromSession }
})
vi.mock('@/lib/supabase/server', () => ({
  createClient: async () => ({
    auth: { getUser },
    from: () => ({
      select: () => ({ eq: () => ({ maybeSingle: profilesMaybeSingle }) }),
    }),
  }),
}))

import { createFounderCheckout, confirmFounderCheckout } from './actions'

beforeEach(() => {
  vi.clearAllMocks()
  // Default signed-in caller resolving to a profile.
  getUser.mockResolvedValue({ data: { user: { id: 'auth-1' } } })
  profilesMaybeSingle.mockResolvedValue({ data: { id: 'profile-1' } })
  resolveStripePriceId.mockResolvedValue(null) // no synced price → inline price_data
  sessionsCreate.mockResolvedValue({ id: 'cs_test_1', url: 'https://checkout.stripe.com/c/pay/cs_test_1' })
})

describe('createFounderCheckout — the no-charge-when-off invariant (billingLive false)', () => {
  beforeEach(() => billingLiveMock.mockResolvedValue(false))

  it('returns { ok:false, notOpen:true } and NEVER touches Stripe', async () => {
    const res = await createFounderCheckout({ tier: 'member' })
    expect(res).toEqual({ ok: false, notOpen: true })
    // THE GUARANTEE: no Stripe session was created. No charge, no card.
    expect(sessionsCreate).not.toHaveBeenCalled()
    expect(sessionsRetrieve).not.toHaveBeenCalled()
    // We also never even resolved a price or read a profile (gate is the first line).
    expect(resolveStripePriceId).not.toHaveBeenCalled()
  })

  it('is OFF for every tier (supporter, member, patron)', async () => {
    for (const tier of ['supporter', 'member', 'patron'] as const) {
      const res = await createFounderCheckout({ tier })
      expect(res).toEqual({ ok: false, notOpen: true })
    }
    expect(sessionsCreate).not.toHaveBeenCalled()
  })
})

describe('createFounderCheckout — live (billingLive true)', () => {
  beforeEach(() => billingLiveMock.mockResolvedValue(true))

  it('creates a mode:payment session with the right founder_tier + profile metadata, returns the URL', async () => {
    const res = await createFounderCheckout({ tier: 'member' })
    expect(res).toEqual({ ok: true, url: 'https://checkout.stripe.com/c/pay/cs_test_1' })

    expect(sessionsCreate).toHaveBeenCalledTimes(1)
    const params = sessionsCreate.mock.calls[0][0]
    // ONE-TIME purchase.
    expect(params.mode).toBe('payment')
    // Identity + kind metadata the webhook / confirm read.
    expect(params.metadata).toMatchObject({ kind: 'founders', founder_tier: 'member', profile_id: 'profile-1' })
    expect(params.client_reference_id).toBe('profile-1')
    // Inline one-time price built from the fixed $250 amount, NO recurring block.
    const line = params.line_items[0]
    expect(line.price_data.unit_amount).toBe(25000)
    expect(line.price_data.currency).toBe('usd')
    expect(line.price_data.recurring).toBeUndefined()
    // Success/cancel routing.
    expect(params.success_url).toContain('/founders/checkout/success')
    expect(params.cancel_url).toContain('/founders/offer')
  })

  it('uses a synced one-time founder price id when present (no inline price_data)', async () => {
    resolveStripePriceId.mockResolvedValue('price_founder_member_onetime')
    await createFounderCheckout({ tier: 'member' })
    const line = sessionsCreate.mock.calls[0][0].line_items[0]
    expect(line.price).toBe('price_founder_member_onetime')
    expect(line.price_data).toBeUndefined()
  })

  it('prices supporter at $25 and patron at $1,000', async () => {
    await createFounderCheckout({ tier: 'supporter' })
    expect(sessionsCreate.mock.calls[0][0].line_items[0].price_data.unit_amount).toBe(2500)
    sessionsCreate.mockClear()
    await createFounderCheckout({ tier: 'patron' })
    expect(sessionsCreate.mock.calls[0][0].line_items[0].price_data.unit_amount).toBe(100000)
  })

  it('refuses an unknown tier without creating a session', async () => {
    const res = await createFounderCheckout({ tier: 'gold' as unknown as 'member' })
    expect(res.ok).toBe(false)
    expect(sessionsCreate).not.toHaveBeenCalled()
  })

  it('requires a signed-in profile (no session created when anonymous)', async () => {
    getUser.mockResolvedValue({ data: { user: null } })
    const res = await createFounderCheckout({ tier: 'member' })
    expect(res).toEqual({ ok: false, needsAuth: true })
    expect(sessionsCreate).not.toHaveBeenCalled()
  })
})

describe('confirmFounderCheckout — gated + ownership-checked grant', () => {
  it('never calls Stripe when billing is OFF', async () => {
    billingLiveMock.mockResolvedValue(false)
    const res = await confirmFounderCheckout('cs_test_1')
    expect(res).toEqual({ ok: false, notOpen: true })
    expect(sessionsRetrieve).not.toHaveBeenCalled()
    expect(grantFounderFromSession).not.toHaveBeenCalled()
  })

  it('grants when the paid session belongs to the caller', async () => {
    billingLiveMock.mockResolvedValue(true)
    sessionsRetrieve.mockResolvedValue({
      payment_status: 'paid',
      metadata: { kind: 'founders', founder_tier: 'member', profile_id: 'profile-1' },
    })
    grantFounderFromSession.mockResolvedValue('member')
    const res = await confirmFounderCheckout('cs_test_1')
    expect(res).toEqual({ ok: true, tier: 'member' })
    expect(grantFounderFromSession).toHaveBeenCalledTimes(1)
  })

  it('refuses a session that belongs to a different profile (no grant)', async () => {
    billingLiveMock.mockResolvedValue(true)
    sessionsRetrieve.mockResolvedValue({
      payment_status: 'paid',
      metadata: { kind: 'founders', founder_tier: 'member', profile_id: 'someone-else' },
    })
    const res = await confirmFounderCheckout('cs_test_1')
    expect(res.ok).toBe(false)
    expect(grantFounderFromSession).not.toHaveBeenCalled()
  })

  it('reports pending (no grant) when the session is not paid yet', async () => {
    billingLiveMock.mockResolvedValue(true)
    sessionsRetrieve.mockResolvedValue({
      payment_status: 'unpaid',
      metadata: { kind: 'founders', founder_tier: 'member', profile_id: 'profile-1' },
    })
    const res = await confirmFounderCheckout('cs_test_1')
    expect(res).toEqual({ ok: false, pending: true })
    expect(grantFounderFromSession).not.toHaveBeenCalled()
  })
})
