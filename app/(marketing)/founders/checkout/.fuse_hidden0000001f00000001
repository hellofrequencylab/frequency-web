'use server'

// FOUNDERS ROUND — the ONE-TIME founding-membership checkout (the Founders Round).
// FULLY GATED behind billingLive() (lib/pricing/settings.ts): the master `billing_live`
// platform flag AND the Stripe env keys. Until the owner flips billing_live (after EIN),
// this whole surface is INERT — `createFounderCheckout` returns a "not open yet" result
// and NEVER touches Stripe, so there is no session, no charge, no card. This mirrors
// ADR-370's OFF-preserves-current-behavior invariant: while the flag is OFF the only
// founding path is the free waitlist reservation (app/(marketing)/founders/actions.ts).
//
// These are ONE-TIME purchases (Stripe mode:'payment'), NOT the recurring Crew/Supporter
// subscriptions in lib/billing/checkout.ts. The three founding tiers and their fixed USD
// amounts are the source of truth here (display copy lives in /founders/offer):
//   supporter  $25     a one-time Founding Supporter
//   member     $250    the Founding Member rate, LOCKED FOR LIFE (capped at 150)
//   patron     $1,000  the Founding Patron
//
// Founding memberships are a membership, not an investment (docs/CONTENT-VOICE.md).

import type Stripe from 'stripe'
import { stripe, appUrl } from '@/lib/billing/stripe'
import { resolveStripePriceId } from '@/lib/billing/pricing-prices'
import { billingLive } from '@/lib/pricing/settings'
import { createClient } from '@/lib/supabase/server'
import {
  grantFounderFromSession,
  FOUNDER_TIERS,
  founderOneTimeAmountCents,
  founderOneTimePriceKey,
  founderTierLabel,
  type FounderTier,
} from '@/lib/billing/founders'

export type FounderCheckoutResult =
  // The flag is OFF (today): the gate refused before any Stripe call. NO session, NO charge.
  | { ok: false; notOpen: true }
  // The caller isn't signed in, so we can't attach the purchase to a profile.
  | { ok: false; needsAuth: true }
  // A real, validated failure once live (bad tier, Stripe could not start the session).
  | { ok: false; error: string }
  // Live + authorized: the hosted Stripe Checkout URL to redirect to.
  | { ok: true; url: string }

/** The signed-in caller's profile id (session-derived), or null when not signed in.
 *  Mirrors the proven derivation in app/(main)/founder/founder-actions.ts: never trust a
 *  client-supplied id; resolve it from the auth session. */
async function getMyProfileId(): Promise<string | null> {
  const supabase = await createClient()
  const {
    data: { user },
  } = await supabase.auth.getUser()
  if (!user) return null
  const { data } = await supabase.from('profiles').select('id').eq('auth_user_id', user.id).maybeSingle()
  return data?.id ?? null
}

/**
 * Start the one-time Founders Round checkout for a tier and return the hosted Stripe URL.
 *
 * FIRST LINE OF DEFENSE (the no-charge invariant): if billingLive() is false we return
 * `{ ok:false, notOpen:true }` immediately, BEFORE touching Stripe. No session is created,
 * no card is taken, nothing is charged. This is the single gate that keeps the Founders
 * Round inert until the owner flips `billing_live`.
 *
 * When live: resolve the tier's one-time Stripe price (a synced founder one-time price id if
 * present, else an inline price_data built from the known USD amount), create a mode:'payment'
 * Checkout Session tagged metadata { kind:'founders', founder_tier, profile_id }, and return
 * its URL. The grant (is_founding_member + locked price) happens on success, not here.
 */
export async function createFounderCheckout(input: { tier: FounderTier }): Promise<FounderCheckoutResult> {
  // ── THE GATE. Nothing below runs while billing is OFF. No Stripe, no charge, no card. ──
  if (!(await billingLive())) return { ok: false, notOpen: true }

  // Validate the tier (default-deny on an unknown value rather than guessing a price).
  const tier = input.tier
  if (!FOUNDER_TIERS.includes(tier)) return { ok: false, error: 'Pick a founding tier.' }

  // Defense in depth: billingLive() already implies stripe is configured, but never let a
  // null client reach a charge call.
  if (!stripe) return { ok: false, notOpen: true }

  // The purchase must attach to a profile (so the grant can flip is_founding_member on success).
  const profileId = await getMyProfileId()
  if (!profileId) return { ok: false, needsAuth: true }

  // Prefer a synced one-time founder price id (from pricing_stripe_prices) when present; else
  // build the price inline from the fixed USD amount, so checkout works even before a sync.
  const priceId = await resolveStripePriceId(founderOneTimePriceKey(tier))
  const lineItem: Stripe.Checkout.SessionCreateParams.LineItem = priceId
    ? { price: priceId, quantity: 1 }
    : {
        quantity: 1,
        price_data: {
          currency: 'usd',
          // mode:'payment' => a ONE-TIME price (no `recurring` block, unlike the subscription path).
          unit_amount: founderOneTimeAmountCents(tier),
          product_data: { name: `Frequency ${founderTierLabel(tier)}` },
        },
      }

  let session: Stripe.Checkout.Session
  try {
    session = await stripe.checkout.sessions.create({
      mode: 'payment',
      line_items: [lineItem],
      client_reference_id: profileId,
      // The webhook + the success-page confirm read these to grant the founding membership.
      metadata: { kind: 'founders', founder_tier: tier, profile_id: profileId },
      payment_intent_data: {
        metadata: { kind: 'founders', founder_tier: tier, profile_id: profileId },
      },
      success_url: `${appUrl()}/founders/checkout/success?session_id={CHECKOUT_SESSION_ID}`,
      cancel_url: `${appUrl()}/founders/offer`,
    })
  } catch (err) {
    console.error('[founders-checkout] failed to create session:', err)
    return { ok: false, error: 'Could not start checkout. Please try again.' }
  }

  if (!session.url) return { ok: false, error: 'Could not start checkout. Please try again.' }
  return { ok: true, url: session.url }
}

export type ConfirmFounderResult =
  | { ok: true; tier: FounderTier }
  | { ok: false; notOpen?: true; pending?: true; error?: string }

/**
 * Webhook-independent confirm on the success redirect: retrieve the session, verify it is a
 * PAID founders session that belongs to THIS signed-in caller, then grant the founding
 * membership (idempotent; the same grant the webhook runs). This guarantees the founder
 * status lands even if the webhook is not wired yet, mirroring confirmCheckout.
 *
 * Still gated: if billing is OFF we never call Stripe here either.
 */
export async function confirmFounderCheckout(sessionId: string): Promise<ConfirmFounderResult> {
  if (!(await billingLive())) return { ok: false, notOpen: true }
  if (!stripe) return { ok: false, notOpen: true }
  if (!sessionId) return { ok: false, error: 'Missing session.' }

  const profileId = await getMyProfileId()
  if (!profileId) return { ok: false, error: 'Please sign in to confirm your founding membership.' }

  let session: Stripe.Checkout.Session
  try {
    // Expand line_items so the grant can record the concrete charged price id as the
    // member's locked_price_id (else it falls back to the payment intent id).
    session = await stripe.checkout.sessions.retrieve(sessionId, { expand: ['line_items'] })
  } catch {
    return { ok: false, error: 'We could not find that checkout.' }
  }

  // Only confirm a session that belongs to this caller (defense against a guessed session id).
  const sessionProfileId = session.metadata?.profile_id ?? session.client_reference_id ?? null
  if (sessionProfileId !== profileId) return { ok: false, error: 'That checkout is not yours.' }

  // Not paid yet (e.g. async payment): report pending, don't grant.
  if (session.payment_status !== 'paid') return { ok: false, pending: true }

  const granted = await grantFounderFromSession(session)
  if (!granted) return { ok: false, error: 'That checkout is not a founding membership.' }
  return { ok: true, tier: granted }
}
